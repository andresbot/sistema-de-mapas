{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend API for Mapa de Reseñas",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init_mysql",
    "prisma:deploy": "prisma migrate deploy",
    "db:test": "node src/scripts/test-prisma.js",
    "prisma:studio": "prisma studio"
  },
  "keywords": ["maps", "reviews", "express", "mysql", "prisma"],
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.0",
    "dotenv": "^16.4.7",
    "cors": "^2.8.5",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "express-validator": "^7.2.1",
    "@prisma/client": "^6.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.9",
    "prisma": "^6.0.0",
    "tsx": "^4.0.0"
  }
}
